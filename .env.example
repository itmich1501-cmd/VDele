# Пример .env файла для production развёртывания.
# На сервере скопируй этот файл в .env и заполни реальными значениями:
#   cp .env.example .env
#   nano .env
#
# ВАЖНО: .env НИКОГДА не коммитить в git — добавь его в .gitignore!

# PostgreSQL
POSTGRES_DB=vdele_db
POSTGRES_USER=vdele_user
POSTGRES_PASSWORD=!Qq12345

# JWT — сгенерируй один раз и сохрани.
# Команда для генерации (на сервере):
#   openssl rand -base64 64
JWT_SECRET=sdfsdfsdfdsffgjghjytjhjsdfs435435sfsdf34543yt

# SmsInt — токен из личного кабинета smsint.ru
SMSINT_TOKEN=hyi3awtoorerm364x20czwvgf5jpbaer7y3xu5lwzdxlesf7kaieox0ndokjw7p0

# Пароли админов — сложные, сохрани в менеджере паролей
ADMIN_VDELE_PASS=VDele!Admin123
ADMIN_VLAVKE_PASS=VLavke!Admin123
